@page "/dashboard"
@using SeriesTracker.Models
@using SeriesTracker.Services
@inject AuthService AuthService
@inject WatchListService WatchListService
@inject NavigationManager Navigation

@if (!AuthService.IsLoggedIn)
{
    <div class="loading-screen">Redirecting...</div>
}
else
{
<div class="dashboard">

    <!-- Header -->
    <header class="dash-header">
        <div class="dash-header-left">
            <span class="brand-icon">⬡</span>
            <h1>Series<span class="brand-accent">Tracker</span></h1>
        </div>
        <div class="dash-header-right">
            <span class="welcome-text">@AuthService.CurrentUser!.Username</span>
            <button class="btn btn-ghost" @onclick="HandleLogout">Logout</button>
        </div>
    </header>

    <!-- Status Summary Strip -->
    <div class="summary-strip">
        @foreach (var status in Enum.GetValues<WatchStatus>())
        {
            <div class="summary-chip @GetBadgeClass(status)">
                <span class="summary-count">
                    @(statusSummary.ContainsKey(status) ? statusSummary[status] : 0)
                </span>
                <span class="summary-label">@GetStatusLabel(status)</span>
            </div>
        }
        <div class="summary-chip summary-total">
            <span class="summary-count">@watchList.Count</span>
            <span class="summary-label">Total</span>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="dash-toolbar">
        <div class="search-wrap">
            <input @bind="searchQuery" @bind:event="oninput"
                   placeholder="Search shows..." class="search-input" />
        </div>
        <div class="toolbar-right">
            <select @bind="filterStatus" class="filter-select">
                <option value="">All Statuses</option>
                @foreach (var status in Enum.GetValues<WatchStatus>())
                {
                    <option value="@status">@GetStatusLabel(status)</option>
                }
            </select>
            <button class="btn btn-primary" @onclick="OpenAddModal">+ Add Show</button>
        </div>
    </div>

    <!-- Table -->
    <div class="table-wrap">
        @if (isLoadingList)
        {
            <div class="table-empty">
                <span class="loading-spinner"></span>
                <p>Loading your watchlist...</p>
            </div>
        }
        else if (!FilteredList.Any())
        {
            <div class="table-empty">
                <span class="empty-icon">⬡</span>
                <p>@(watchList.Any() ? "No shows match your filter." : "Your watchlist is empty. Add your first show!")</p>
            </div>
        }
        else
        {
            <table class="tracker-table">
                <thead>
                    <tr>
                        <th>Show Name</th>
                        <th>Seasons</th>
                        <th>Airing</th>
                        <th>My Season</th>
                        <th>Episode</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in FilteredList)
                    {
                        <tr class="table-row">
                            <td class="col-showname">@entry.ShowName</td>
                            <td class="col-center">@entry.TotalSeasons</td>
                            <td class="col-center">
                                <span class="airing-badge @(entry.IsOngoing ? "airing-ongoing" : "airing-ended")">
                                    @(entry.IsOngoing ? "Ongoing" : "Ended")
                                </span>
                            </td>
                            <td class="col-center">@entry.CurrentSeason</td>
                            <td class="col-episode">
                                <div class="episode-control">
                                    <button class="ep-btn" @onclick="() => DecrementEpisode(entry)"
                                            disabled="@(entry.CurrentEpisode <= 1)">−</button>
                                    <span class="ep-num">@entry.CurrentEpisode</span>
                                    <button class="ep-btn" @onclick="() => IncrementEpisode(entry)">+</button>
                                </div>
                            </td>
                            <td class="col-center">
                                <span class="badge @GetBadgeClass(entry.WatchStatus)">
                                    @GetStatusLabel(entry.WatchStatus)
                                </span>
                            </td>
                            <td class="col-actions">
                                <button class="btn btn-ghost" @onclick="() => OpenEditModal(entry)">Edit</button>
                                <button class="btn btn-danger" @onclick="() => ConfirmDelete(entry)">Remove</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <!-- Add / Edit Modal -->
    @if (showModal)
    {
        <div class="modal-overlay" @onclick="CloseModal">
            <div class="modal" @onclick:stopPropagation="true">
                <h3>@(isEditing ? "Edit Show" : "Add New Show")</h3>

                <div class="form-group">
                    <label>Show Name *</label>
                    <input @bind="formEntry.ShowName" placeholder="e.g. Attack on Titan" />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Total Seasons</label>
                        <input @bind="formEntry.TotalSeasons" placeholder="e.g. 4 or -" />
                    </div>
                    <div class="form-group">
                        <label>Airing Status</label>
                        <select @bind="formIsOngoing">
                            <option value="false">Ended</option>
                            <option value="true">Ongoing</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>My Current Season</label>
                        <input @bind="formEntry.CurrentSeason" placeholder="e.g. 2 or -" />
                    </div>
                    <div class="form-group">
                        <label>Current Episode *</label>
                        <input type="number" @bind="formEntry.CurrentEpisode" min="1" />
                    </div>
                </div>

                <div class="form-group">
                    <label>Watch Status</label>
                    <select @bind="formEntry.WatchStatus">
                        @foreach (var status in Enum.GetValues<WatchStatus>())
                        {
                            <option value="@status">@GetStatusLabel(status)</option>
                        }
                    </select>
                </div>

                @if (!string.IsNullOrEmpty(modalMessage))
                {
                    <div class="alert @(modalSuccess ? "alert-success" : "alert-error")">
                        @modalMessage
                    </div>
                }

                <div class="modal-actions">
                    <button class="btn btn-ghost" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-primary" @onclick="HandleSave" disabled="@isSaving">
                        @(isSaving ? "Saving..." : (isEditing ? "Save Changes" : "Add Show"))
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- Delete Confirm Modal -->
    @if (showDeleteConfirm)
    {
        <div class="modal-overlay" @onclick="() => showDeleteConfirm = false">
            <div class="modal modal-sm" @onclick:stopPropagation="true">
                <h3>Remove Show</h3>
                <p class="delete-msg">
                    Remove <strong>@entryToDelete?.ShowName</strong> from your watchlist?
                    This cannot be undone.
                </p>
                <div class="modal-actions">
                    <button class="btn btn-ghost" @onclick="() => showDeleteConfirm = false">Cancel</button>
                    <button class="btn btn-primary btn-confirm-delete" @onclick="HandleDelete">Remove</button>
                </div>
            </div>
        </div>
    }

</div>
}

@code {
    private List<WatchListEntry> watchList = [];
    private Dictionary<WatchStatus, int> statusSummary = [];
    private bool isLoadingList = true;

    private string searchQuery = "";
    private string filterStatus = "";

    private bool showModal = false;
    private bool isEditing = false;
    private bool isSaving = false;
    private string modalMessage = "";
    private bool modalSuccess = false;
    private WatchListEntry formEntry = new();
    private string formIsOngoing = "false";

    private bool showDeleteConfirm = false;
    private WatchListEntry? entryToDelete;

    private IEnumerable<WatchListEntry> FilteredList => watchList
        .Where(e =>
            (string.IsNullOrEmpty(searchQuery) ||
             e.ShowName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(filterStatus) ||
             e.WatchStatus.ToString() == filterStatus));

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }
        await LoadWatchList();
    }

    private async Task LoadWatchList()
    {
        isLoadingList = true;
        var userId = AuthService.CurrentUser!.Id!;
        watchList = await WatchListService.GetUserWatchListAsync(userId);
        statusSummary = await WatchListService.GetStatusSummaryAsync(userId);
        isLoadingList = false;
    }

    private void OpenAddModal()
    {
        formEntry = new WatchListEntry
        {
            UserId = AuthService.CurrentUser!.Id!,
            TotalSeasons = "-",
            CurrentSeason = "-",
            CurrentEpisode = 1,
            WatchStatus = WatchStatus.Watching
        };
        formIsOngoing = "false";
        isEditing = false;
        modalMessage = "";
        showModal = true;
    }

    private void OpenEditModal(WatchListEntry entry)
    {
        formEntry = new WatchListEntry
        {
            Id = entry.Id,
            UserId = entry.UserId,
            ShowName = entry.ShowName,
            TotalSeasons = entry.TotalSeasons,
            IsOngoing = entry.IsOngoing,
            CurrentSeason = entry.CurrentSeason,
            CurrentEpisode = entry.CurrentEpisode,
            WatchStatus = entry.WatchStatus,
            DateAdded = entry.DateAdded
        };
        formIsOngoing = entry.IsOngoing ? "true" : "false";
        isEditing = true;
        modalMessage = "";
        showModal = true;
    }

    private async Task HandleSave()
    {
        isSaving = true;
        modalMessage = "";
        formEntry.IsOngoing = formIsOngoing == "true";

        var (success, message) = isEditing
            ? await WatchListService.UpdateEntryAsync(formEntry)
            : await WatchListService.AddEntryAsync(formEntry);

        modalSuccess = success;
        modalMessage = message;

        if (success)
        {
            await LoadWatchList();
            await Task.Delay(800);
            CloseModal();
        }

        isSaving = false;
    }

    private void ConfirmDelete(WatchListEntry entry)
    {
        entryToDelete = entry;
        showDeleteConfirm = true;
    }

    private async Task HandleDelete()
    {
        if (entryToDelete?.Id == null) return;
        await WatchListService.DeleteEntryAsync(entryToDelete.Id);
        showDeleteConfirm = false;
        entryToDelete = null;
        await LoadWatchList();
    }

    private async Task IncrementEpisode(WatchListEntry entry)
    {
        await WatchListService.IncrementEpisodeAsync(entry.Id!);
        entry.CurrentEpisode++;
        statusSummary = await WatchListService.GetStatusSummaryAsync(AuthService.CurrentUser!.Id!);
    }

    private async Task DecrementEpisode(WatchListEntry entry)
    {
        await WatchListService.DecrementEpisodeAsync(entry.Id!, entry.CurrentEpisode);
        if (entry.CurrentEpisode > 1) entry.CurrentEpisode--;
        statusSummary = await WatchListService.GetStatusSummaryAsync(AuthService.CurrentUser!.Id!);
    }

    private void CloseModal()
    {
        showModal = false;
        modalMessage = "";
    }

    private void HandleLogout() => AuthService.Logout();

    private static string GetBadgeClass(WatchStatus status) => status switch
    {
        WatchStatus.Watching    => "badge-watching",
        WatchStatus.Completed   => "badge-completed",
        WatchStatus.Dropped     => "badge-dropped",
        WatchStatus.PlanToWatch => "badge-plan",
        WatchStatus.OnHold      => "badge-onhold",
        _ => ""
    };

    private static string GetStatusLabel(WatchStatus status) => status switch
    {
        WatchStatus.Watching    => "Watching",
        WatchStatus.Completed   => "Completed",
        WatchStatus.Dropped     => "Dropped",
        WatchStatus.PlanToWatch => "Plan to Watch",
        WatchStatus.OnHold      => "On Hold",
        _ => status.ToString()
    };
}

<style>
    .dashboard {
        min-height: 100vh;
        background: var(--bg-primary);
        padding-bottom: 60px;
    }

    /* Header */
    .dash-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 32px;
        background: var(--bg-card);
        border-bottom: 1px solid var(--border-subtle);
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .dash-header-left {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .dash-header-left h1 {
        font-size: 22px;
        letter-spacing: 0.08em;
    }

    .brand-icon {
        color: var(--accent-primary);
        font-size: 22px;
        filter: drop-shadow(0 0 8px var(--accent-primary));
    }

    .brand-accent { color: var(--accent-primary); }

    .dash-header-right {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .welcome-text {
        color: var(--text-secondary);
        font-size: 13px;
        font-family: var(--font-display);
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    /* Summary strip */
    .summary-strip {
        display: flex;
        gap: 10px;
        padding: 16px 32px;
        background: var(--bg-secondary);
        border-bottom: 1px solid var(--border-subtle);
        flex-wrap: wrap;
    }

    .summary-chip {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 14px;
        border-radius: 20px;
        font-family: var(--font-display);
    }

    .summary-count {
        font-size: 18px;
        font-weight: 700;
        line-height: 1;
    }

    .summary-label {
        font-size: 11px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        opacity: 0.8;
    }

    .summary-total {
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--border-subtle);
        color: var(--text-secondary);
        margin-left: auto;
    }

    /* Toolbar */
    .dash-toolbar {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 20px 32px;
        flex-wrap: wrap;
    }

    .search-wrap { flex: 1; min-width: 200px; }

    .search-input {
        background: var(--bg-elevated);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius);
        color: var(--text-primary);
        font-family: var(--font-body);
        font-size: 14px;
        padding: 10px 14px;
        width: 100%;
        outline: none;
        transition: border-color var(--transition);
    }

    .search-input:focus { border-color: var(--accent-primary); }
    .search-input::placeholder { color: var(--text-muted); }

    .toolbar-right {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .filter-select {
        width: auto;
        min-width: 150px;
        padding: 10px 14px;
    }

    /* Table */
    .table-wrap {
        padding: 0 32px;
        overflow-x: auto;
    }

    .tracker-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }

    .tracker-table thead tr {
        border-bottom: 2px solid var(--border-accent);
    }

    .tracker-table th {
        color: var(--text-muted);
        font-family: var(--font-display);
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.1em;
        padding: 12px 16px;
        text-align: left;
        text-transform: uppercase;
    }

    .table-row {
        border-bottom: 1px solid var(--border-subtle);
        transition: background var(--transition);
    }

    .table-row:hover { background: var(--bg-elevated); }

    .tracker-table td {
        padding: 14px 16px;
        vertical-align: middle;
    }

    .col-showname {
        font-weight: 500;
        color: var(--text-primary);
        min-width: 180px;
    }

    .col-center { text-align: center; color: var(--text-secondary); }

    .airing-badge {
        border-radius: 4px;
        font-family: var(--font-display);
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.06em;
        padding: 3px 8px;
        text-transform: uppercase;
    }

    .airing-ongoing {
        background: rgba(0,230,118,0.1);
        color: var(--status-completed);
        border: 1px solid rgba(0,230,118,0.2);
    }

    .airing-ended {
        background: rgba(136,136,170,0.1);
        color: var(--text-secondary);
        border: 1px solid rgba(136,136,170,0.2);
    }

    /* Episode control */
    .col-episode { text-align: center; }

    .episode-control {
        display: inline-flex;
        align-items: center;
        gap: 0;
        background: var(--bg-elevated);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius);
        overflow: hidden;
    }

    .ep-btn {
        background: transparent;
        border: none;
        color: var(--text-secondary);
        cursor: pointer;
        font-size: 16px;
        padding: 4px 10px;
        transition: all var(--transition);
        line-height: 1;
    }

    .ep-btn:hover:not(:disabled) {
        background: var(--accent-glow);
        color: var(--accent-primary);
    }

    .ep-btn:disabled { opacity: 0.3; cursor: not-allowed; }

    .ep-num {
        color: var(--text-primary);
        font-family: var(--font-display);
        font-size: 15px;
        font-weight: 600;
        min-width: 36px;
        text-align: center;
        padding: 4px 0;
    }

    .col-actions {
        display: flex;
        gap: 6px;
        white-space: nowrap;
    }

    /* Empty / loading states */
    .table-empty {
        text-align: center;
        padding: 80px 20px;
        color: var(--text-muted);
    }

    .empty-icon {
        font-size: 40px;
        display: block;
        margin-bottom: 12px;
        opacity: 0.3;
        color: var(--accent-primary);
    }

    .loading-spinner {
        display: inline-block;
        width: 28px;
        height: 28px;
        border: 2px solid var(--border-subtle);
        border-top-color: var(--accent-primary);
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
        margin-bottom: 12px;
    }

   

    /* Delete modal */
    .modal-sm { max-width: 380px; }

    .delete-msg {
        color: var(--text-secondary);
        font-size: 14px;
        margin-bottom: 8px;
        line-height: 1.6;
    }

    .delete-msg strong { color: var(--text-primary); }

    .btn-confirm-delete {
        background: var(--accent-primary) !important;
    }

    .loading-screen {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100vh;
        color: var(--text-muted);
        font-family: var(--font-display);
        letter-spacing: 0.1em;
    }
</style>